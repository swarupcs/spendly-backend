generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            Int            @id @default(autoincrement())
  email         String         @unique
  name          String
  passwordHash  String?
  role          Role           @default(USER)
  isActive      Boolean        @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  authProvider  String         @default("local")
  googleId      String?        @unique
  googlePicture String?

  emailVerified                Boolean   @default(false)
  emailVerificationToken       String?   @unique
  emailVerificationTokenExpiry DateTime?

  passwordResetToken       String?   @unique
  passwordResetTokenExpiry DateTime?

  chatMessages       ChatMessage[]
  expenses           Expense[]
  refreshTokens      RefreshToken[]
  settings           UserSettings?
  budgets            Budget[]
  recurringExpenses  RecurringExpense[]
  goals              FinancialGoal[]
  alertLogs          AlertLog[]
  subscription       Subscription?
  toolCallLogs       ToolCallLog[]
  merchantRules      MerchantRule[]
  anomalyAlerts      AnomalyAlert[]

  @@map("users")
}

model UserSettings {
  id                   Int      @id @default(autoincrement())
  userId               Int      @unique
  emailNotifications   Boolean  @default(true)
  budgetAlerts         Boolean  @default(true)
  weeklyReport         Boolean  @default(false)
  onboardingCompleted  Boolean  @default(false)
  currency             String   @default("INR")
  alertThreshold       Float?
  
  // LLM Overrides
  llmProvider          String?
  llmModel             String?

  monthlyIncome        Float?
  netWorthAssets       Float?   @default(0)
  netWorthLiabilities  Float?   @default(0)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model GlobalSettings {
  id          Int      @id @default(1)
  llmProvider String   @default("gemini")
  llmModel    String?
  updatedAt   DateTime @updatedAt

  @@map("global_settings")
}

model RefreshToken {
  id        Int       @id @default(autoincrement())
  token     String    @unique
  userId    Int
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

model Expense {
  id               Int      @id @default(autoincrement())
  title            String
  amount           Float
  currency         String   @default("INR")
  exchangeRate     Float    @default(1.0)
  convertedAmount  Float    @default(0)
  category         Category @default(OTHER)
  date             String
  notes            String?
  // New fields (migration: add_merchant_tax_networth_toollog)
  merchant         String?
  isTaxDeductible  Boolean  @default(false)
  userId           Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, date])
  @@index([userId, category])
  @@index([userId, merchant])
  @@map("expenses")
}

model RecurringExpense {
  id          Int       @id @default(autoincrement())
  userId      Int
  title       String
  amount      Float
  category    Category  @default(OTHER)
  frequency   Frequency
  startDate   String
  nextDueDate String
  isActive    Boolean   @default(true)
  notes       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([nextDueDate])
  @@map("recurring_expenses")
}

model Budget {
  id        Int      @id @default(autoincrement())
  userId    Int
  category  Category
  amount    Float
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, category])
  @@index([userId])
  @@map("budgets")
}

model ChatMessage {
  id        Int      @id @default(autoincrement())
  threadId  String
  userId    Int
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([threadId])
  @@index([userId, threadId])
  @@map("chat_messages")
}

model FinancialGoal {
  id            Int       @id @default(autoincrement())
  userId        Int
  name          String
  type          GoalType  @default(SAVINGS)
  targetAmount  Float
  currentAmount Float     @default(0)
  category      Category?
  period        String?
  deadline      String?
  isCompleted   Boolean   @default(false)
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("financial_goals")
}

model AlertLog {
  id     Int      @id @default(autoincrement())
  userId Int
  type   String
  ref    String
  sentAt DateTime @default(now())
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, ref])
  @@index([userId])
  @@map("alert_logs")
}

model Subscription {
  id                 Int                @id @default(autoincrement())
  userId             Int                @unique
  plan               Plan               @default(FREE)
  status             SubscriptionStatus @default(ACTIVE)
  razorpaySubId      String?            @unique
  razorpayCustomerId String?
  currentPeriodEnd   DateTime?
  cancelAtPeriodEnd  Boolean            @default(false)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  user               User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("subscriptions")
}

// New model (migration: add_merchant_tax_networth_toollog)
model ToolCallLog {
  id         Int      @id @default(autoincrement())
  userId     Int
  threadId   String?
  toolName   String
  args       Json
  result     Json?
  durationMs Int?
  success    Boolean  @default(true)
  error      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([toolName])
  @@index([userId, createdAt])
  @@map("tool_call_logs")
}

// Expense auto-categorization (Phase 2.5)
model MerchantRule {
  id        Int      @id @default(autoincrement())
  userId    Int
  merchant  String
  title     String?
  category  Category
  hitCount  Int      @default(1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, merchant])
  @@index([userId])
  @@index([userId, merchant])
  @@map("merchant_rules")
}

// AI Anomaly Detection (Phase 2.3)
model AnomalyAlert {
  id          Int      @id @default(autoincrement())
  userId      Int
  category    Category
  amount      Float
  expectedAvg Float
  percentage  Float
  explanation String?
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("anomaly_alerts")
}

enum Plan {
  FREE
  PRO
}

enum SubscriptionStatus {
  ACTIVE
  PENDING
  CANCELLED
  EXPIRED
}

enum GoalType {
  SAVINGS
  SPENDING_LIMIT
}

enum Role {
  USER
  ADMIN
}

enum Frequency {
  DAILY
  WEEKLY
  MONTHLY
  YEARLY
}

enum Category {
  DINING
  SHOPPING
  TRANSPORT
  ENTERTAINMENT
  UTILITIES
  HEALTH
  EDUCATION
  OTHER
}

